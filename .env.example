# LLM provider: "openai", "anthropic", or "azure"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=
LLM_API_VERSION=2024-12-01-preview

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# Admin
ADMIN_PASSWORD=

# Server
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=info
DEFAULT_STRATEGY=common_identity
ENABLE_THINK=false
